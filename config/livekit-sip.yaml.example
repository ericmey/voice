# livekit-sip configuration.
#
# Copy to config/livekit-sip.yaml (gitignored) before starting the
# voice-livekit-sip container. Keys here must match the ones in
# livekit.yaml — the sip process authenticates to livekit-server with them.

log_level: info

# ---- LiveKit server credentials --------------------------------------
# Same key/secret pair livekit-server uses in ../livekit.yaml.
api_key: "devkey"
api_secret: "devsecret-change-me-before-real-use"

# WebSocket URL of livekit-server. livekit-sip runs network_mode: host (it
# needs the host's real IP for SIP/RTP), so it is NOT on the compose network —
# it reaches the server and redis via the ports they forward to the host.
ws_url: "ws://127.0.0.1:7880"

# ---- Redis (REQUIRED) ------------------------------------------------
# livekit-sip uses Redis for SIP session state. No in-memory fallback.
# 127.0.0.1:6379 — redis forwards this port to the host (see docker-compose.yaml).
redis:
  address: "127.0.0.1:6379"

# ---- SIP listener ----------------------------------------------------
sip_port: 5060
rtp_port_range_start: 10000
rtp_port_range_size: 10000

# Advertise the host's real IP in SDP. Needed when the SIP service sits
# behind NAT (typical home setup). Auto-detects via STUN; override with
# `external_ip:` if the detection is wrong.
use_external_ip: true
