# Host-side OpenTelemetry Collector for the openclaw-livekit observability
# stack. Renders into ${OPENCLAW_OTELCOL_HOME}/config.yaml at install time.
#
# Pipelines:
#   metrics/host       hostmetrics scraper       service.name=host-mac
#   metrics/docker     docker_stats receiver     service.name=<container.name> (per container)
#   metrics/httpcheck  httpcheck receiver        service.name=httpcheck
#   logs/openclaw      filelog receiver          service.name=openclaw-gateway
#   logs/agents        filelog receiver          service.name=openclaw-livekit-<agent>
#
# Exports OTLP/HTTP at http://localhost:4318 (the SigNoz collector).
#
# Template variables (substituted by scripts/install-host-otel-collector.sh):
#   {{HOSTNAME}}              the macOS hostname (auto-detected at install time)
#   {{HOME}}                  the operator's $HOME
#   {{OPENCLAW_GATEWAY_LOGS}} ~/.openclaw/logs
#   {{LIVEKIT_VOICE_LOGS}}    ${LIVEKIT_VOICE_LOGS:-${REPO_ROOT}/logs/voice}

receivers:
  # ---- Tier 1: host metrics ------------------------------------------------
  # Scrapes /proc-equivalents on macOS (BSD sysctl + Mach kernel). Every
  # 30s so chart resolution is high enough to correlate with span gaps.
  hostmetrics:
    collection_interval: 30s
    # root_path is Linux-only — on macOS the scrapers use BSD sysctl + Mach
    # kernel APIs, no fakeable mount root.
    scrapers:
      cpu:
        metrics:
          system.cpu.utilization:
            enabled: true
          system.cpu.logical.count:
            enabled: true
      memory:
        metrics:
          system.memory.utilization:
            enabled: true
      load: {}
      disk: {}
      filesystem:
        metrics:
          system.filesystem.utilization:
            enabled: true
      network: {}
      paging: {}
      processes: {}
      # process: # explicit per-process scrape disabled on purpose
                # — high cardinality, redundant with the agent SDK's
                # own SystemMetricsInstrumentor and the OpenClaw gateway
                # diagnostics-otel plugin.

  # ---- Tier 2: docker container stats --------------------------------------
  # Reads /var/run/docker.sock (mounted via launchd plist). Picks up every
  # container in the LiveKit + SigNoz compose stacks.
  docker_stats:
    endpoint: unix:///var/run/docker.sock
    collection_interval: 30s
    timeout: 20s
    metrics:
      container.cpu.utilization:
        enabled: true
      container.memory.percent:
        enabled: true
      container.memory.usage.total:
        enabled: true
      container.network.io.usage.rx_bytes:
        enabled: true
      container.network.io.usage.tx_bytes:
        enabled: true
      container.blockio.io_service_bytes_recursive:
        enabled: true

  # ---- Tier 4: external dependency uptime ----------------------------------
  # Pings vendor public endpoints unauthenticated; metric records reachability
  # + latency, not auth correctness. Intentionally low-frequency so we don't
  # rate-limit ourselves on the vendor side.
  httpcheck/vendors:
    targets:
      - endpoint: https://api.openai.com/v1/models
        method: GET
      - endpoint: https://api.x.ai/v1/models
        method: GET
      - endpoint: https://generativelanguage.googleapis.com/
        method: GET
      - endpoint: https://api.elevenlabs.io/v1/voices
        method: GET
      - endpoint: https://api.cartesia.ai/
        method: GET
      - endpoint: https://api.deepgram.com/
        method: GET
      - endpoint: http://musubi.mey.house:8100/health
        method: GET
    collection_interval: 60s

  # ---- Filelog: gateway logs (file-based, OpenClaw also pushes via OTLP) ---
  # The OpenClaw gateway already pushes logs via its diagnostics-otel plugin,
  # but the file logs carry additional structured context (config-audit,
  # cache-trace) that aren't in the OTLP feed. We tail them here so SigNoz
  # has a complete view.
  filelog/openclaw:
    include:
      - {{OPENCLAW_GATEWAY_LOGS}}/gateway.log
      - {{OPENCLAW_GATEWAY_LOGS}}/gateway.err.log
    start_at: end
    include_file_name: true
    include_file_path: true

  # ---- Filelog: agent logs (Python LiveKit agents) ------------------------
  # The agents push logs via OTel LoggingInstrumentor too; tailing the files
  # is belt-and-suspenders for the cases where the SDK isn't initialized
  # yet (e.g. crash before setup_otel_tracing runs).
  filelog/agents:
    include:
      - {{LIVEKIT_VOICE_LOGS}}/agent-*.log
      - {{LIVEKIT_VOICE_LOGS}}/agent-*.err.log
    start_at: end
    include_file_name: true
    include_file_path: true

processors:
  # Auto-discover host.name, host.id, os.* attributes so SigNoz' hostmetrics
  # dashboards work out of the box.
  resourcedetection/system:
    detectors: [system, env]
    system:
      hostname_sources: [os]

  # Tag the host pipeline with service.name=host-mac so it shows up in the
  # SigNoz services list as one entry.
  resource/host:
    attributes:
      - key: service.name
        value: host-mac
        action: upsert

  # Tag the httpcheck pipeline with service.name=httpcheck so all the vendor
  # uptime panels group under one service.
  resource/httpcheck:
    attributes:
      - key: service.name
        value: httpcheck
        action: upsert

  # For docker_stats, copy container.name → service.name so each container
  # appears as its own service node in SigNoz' service map.
  transform/container_to_service:
    metric_statements:
      - context: resource
        statements:
          - set(attributes["service.name"], attributes["container.name"]) where attributes["container.name"] != nil

  # Tag the openclaw gateway file-log pipeline so it merges with the
  # gateway's OTLP-pushed logs under the same service.name.
  resource/openclaw_logs:
    attributes:
      - key: service.name
        value: openclaw-gateway
        action: upsert
      - key: openclaw.log.source
        value: file
        action: insert

  # Tag the agent file-log pipeline. service.name is set per-file via the
  # filename (one filelog instance covers all 3 agents); we let the body
  # parser pick that up if needed, but otherwise default to a generic
  # tag and rely on the OTLP-pushed logs for the per-agent breakdown.
  resource/agent_logs:
    attributes:
      - key: service.name
        value: openclaw-livekit-host
        action: upsert
      - key: openclaw.log.source
        value: file
        action: insert

  # Standard batching: 10s window or 1024 records, whichever first.
  batch:
    timeout: 10s
    send_batch_size: 1024

exporters:
  # Single OTLP target: the SigNoz collector running in the local
  # docker-compose stack. Both LiveKit agents and the OpenClaw gateway
  # already push to this endpoint.
  otlphttp:
    endpoint: http://localhost:4318
    tls:
      insecure: true

extensions:
  # Health check so launchd can detect a wedged collector.
  health_check:
    endpoint: 127.0.0.1:13133

  # zpages for live-debug (collector-side trace inspection).
  zpages:
    endpoint: 127.0.0.1:55679

service:
  extensions: [health_check, zpages]
  telemetry:
    logs:
      level: info
      encoding: json
  pipelines:
    metrics/host:
      receivers: [hostmetrics]
      processors: [resourcedetection/system, resource/host, batch]
      exporters: [otlphttp]
    metrics/docker:
      receivers: [docker_stats]
      processors: [resourcedetection/system, transform/container_to_service, batch]
      exporters: [otlphttp]
    metrics/httpcheck:
      receivers: [httpcheck/vendors]
      processors: [resourcedetection/system, resource/httpcheck, batch]
      exporters: [otlphttp]
    logs/openclaw:
      receivers: [filelog/openclaw]
      processors: [resourcedetection/system, resource/openclaw_logs, batch]
      exporters: [otlphttp]
    logs/agents:
      receivers: [filelog/agents]
      processors: [resourcedetection/system, resource/agent_logs, batch]
      exporters: [otlphttp]
