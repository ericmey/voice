# livekit-server runtime config.
#
# Copy to config/livekit.yaml (gitignored) and edit:
#   - `keys`: generate a strong secret; the devkey/devsecret default below is
#     only useful for a first-boot smoke test on a disconnected box.
#   - `redis.address`: `redis:6379` — the compose service name. The
#     livekit-server container is on the compose bridge network, so it reaches
#     redis by service name on both Linux and Mac. (Do NOT use
#     host.docker.internal — that routes to the host, not the redis container.)
#
# Bind-mounted into the voice-livekit-server container at /etc/livekit.yaml.

port: 7880

rtc:
  tcp_port: 7881
  udp_port: 7882
  use_external_ip: true

# livekit-sip coordination. Without this, `lk sip ...` returns
# "sip not connected (redis required)".
redis:
  address: redis:6379

keys:
  devkey: devsecret-change-me-before-real-use

log_level: info
