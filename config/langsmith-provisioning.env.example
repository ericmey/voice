# LangSmith provisioning credentials — EXAMPLE / TEMPLATE.
#
# Copy to secrets/langsmith-provisioning.env (gitignored, mode 0600)
# and fill in real values. Used ONLY by ops/langsmith/provision.py
# for infrastructure-as-code apply runs. Tracing ingest at runtime
# uses a different (lower-privilege) personal-token key in
# secrets/livekit-agents.env.
#
# How to get each value:
#
#   LANGSMITH_API_KEY    — LangSmith Settings → API Keys → "Create API Key"
#                          MUST be a service key (lsv2_sk_*). Personal
#                          tokens (lsv2_pt_*) lack workspace-write perms.
#   LANGSMITH_ENDPOINT   — usually https://api.smith.langchain.com
#                          (self-hosted: your instance URL)
#   LANGSMITH_PROJECT    — name of the project in LangSmith UI. Quote
#                          if it contains spaces (e.g., "Harem World").
#   LANGSMITH_WORKSPACE_ID — uuid of the workspace this project lives in.
#                            Find via:
#                              curl -H "x-api-key: $KEY" \
#                                https://api.smith.langchain.com/api/v1/workspaces
#                            Use the "id" field of the matching workspace.

LANGSMITH_API_KEY=lsv2_sk_your-service-key-here
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT="Your Project Name"
LANGSMITH_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
