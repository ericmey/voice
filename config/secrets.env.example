# OpenClaw LiveKit agent secrets — EXAMPLE / TEMPLATE.
#
# Copy to secrets/livekit-agents.env at the repo root (gitignored) and
# fill in real values. scripts/deploy-agents.sh reads from that path
# and renders per-agent launchd plists.
#
# Override location: OPENCLAW_SECRETS=/abs/path/to/file make deploy
#
# Rotation workflow:
#   1. Update value(s) in secrets/livekit-agents.env.
#   2. Re-run scripts/deploy-agents.sh — it re-renders the plists in
#      ~/Library/LaunchAgents/ and kickstarts each agent so the new
#      values take effect without a full reinstall.

# ---- LiveKit (shared by all agents) ----
# Must match livekit.yaml and livekit-sip.yaml.
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-before-real-use

# ---- External APIs (shared) ----
# Google Gemini API key — realtime voice (nyla, aoi) and chained LLM (party).
GOOGLE_API_KEY=your-google-api-key-here

# ---- OpenClaw gateway auth (shared) ----
# Used by tools that call back into the gateway (memory, sessions, etc.).
GATEWAY_AUTH_TOKEN=your-gateway-token-here

# ---- Per-agent Discord bot tokens ----
# The deploy script maps each agent to DISCORD_BOT_TOKEN in its plist:
#   nyla  -> DISCORD_TOKEN_NYLA
#   aoi   -> DISCORD_TOKEN_AOI
#   party -> DISCORD_TOKEN_NYLA (reuses Nyla's token; party is the
#                                 chained-STT persona, not a separate bot)
DISCORD_TOKEN_NYLA=your-nyla-discord-bot-token
DISCORD_TOKEN_AOI=your-aoi-discord-bot-token

# ---- Musubi canonical API (v1.0, agent-as-tenant per ADR 0030) ----
# Bearer JWTs minted from the Musubi core's JWT_SIGNING_KEY. Mint with:
#   python3 -c "import jwt,time; print(jwt.encode({'iss':'<oauth_authority>',
#     'aud':'musubi','sub':'livekit-<agent>',
#     'presence':'<agent>/voice','scope':'<agent>/*:rw <agent>/*/*:rw */*:r */*/*:r',
#     'iat':int(time.time()),'exp':int(time.time())+365*24*3600},
#     '<jwt_signing_key>', algorithm='HS256'))"
# Party reuses Nyla's token (mirrors Nyla's namespace / presence).
MUSUBI_V2_BASE_URL=http://musubi.mey.house:8100/v1
MUSUBI_V2_TOKEN_NYLA=your-musubi-jwt-for-presence-nyla-voice
MUSUBI_V2_TOKEN_AOI=your-musubi-jwt-for-presence-aoi-voice

# ---- OpenTelemetry → SigNoz (primary observability stack) ----
# Standardized 2026-05-01: SigNoz is the primary backend for traces,
# logs, and metrics. Boot it once with `make signoz-up`, complete the
# in-UI signup at http://localhost:8080, and every LiveKit framework
# span (session/turn/LLM/tool/STT/TTS) plus every outbound HTTP call
# flows there. See docs/OBSERVABILITY.md for the drill-down workflow.
OPENCLAW_OTEL_ENABLED=true
# Comma-separated exporter list: otlp (SigNoz), phoenix, langsmith,
# console. Default = "otlp". To dual-export to LangSmith add "langsmith"
# and fill in the LangSmith block below.
OPENCLAW_OTEL_EXPORTERS=otlp
# Resource identity stamped on every span and log.
OPENCLAW_DEPLOYMENT_ENVIRONMENT=production
OPENCLAW_SERVICE_VERSION=dev
# Set to "true" for verbose stderr diagnostics + always-on console exporter.
OPENCLAW_OTEL_DEBUG=false
# Disable HTTP auto-instrumentation if it interferes with something.
OPENCLAW_OTEL_HTTP_INSTRUMENTATION=true

# --- SigNoz / generic OTLP exporter (default backend) ---
# Local SigNoz collector listens on :4318 (HTTP) when `make signoz-up`
# is running. Point at any other OTLP endpoint to send to Datadog,
# Honeycomb, Grafana Cloud, etc. (drop /v1/traces and let the SDK pick).
OPENCLAW_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Optional — only needed for hosted backends that require an auth header.
# OPENCLAW_OTLP_HEADERS=x-honeycomb-team=<key>

# --- OTel logs pipeline (auto-on with otlp/phoenix/console exporter) ---
# When enabled, Python `logging` records ship as OTLP log records to
# whatever the otlp exporter is pointed at (SigNoz, Loki via collector,
# Datadog Logs). SigNoz auto-correlates them to spans by trace_id.
OPENCLAW_OTEL_LOGS_ENABLED=true
# Optional explicit logs endpoint (defaults to OPENCLAW_OTLP_ENDPOINT
# with /v1/traces rewritten to /v1/logs).
# OPENCLAW_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs

# --- Audio recording (opt-in) ---
# When ON, livekit-egress writes each call's audio to disk and the
# active call span gets `openclaw.audio.path` (and `.url` if a public
# base URL is set). See docs/OBSERVABILITY.md "Audio recording".
OPENCLAW_RECORD_AUDIO=false
# OPENCLAW_AUDIO_PUBLIC_BASE_URL=https://media.example/recordings
LIVEKIT_EGRESS_HOST_RECORDINGS_DIR=./logs/voice/recordings
LIVEKIT_EGRESS_CONTAINER_RECORDINGS_DIR=/recordings

# --- Phoenix exporter (optional, add "phoenix" to OPENCLAW_OTEL_EXPORTERS) ---
# Self-hosted or Arize-cloud Phoenix backend. Defaults to localhost OSS.
# OPENCLAW_PHOENIX_ENDPOINT=http://localhost:6006/v1/traces
# OPENCLAW_PHOENIX_HEADERS=api_key=<your-arize-key>

# --- LangSmith exporter (legacy, add "langsmith" to OPENCLAW_OTEL_EXPORTERS) ---
# Repo migrated off LangSmith on 2026-05-01 — see docs/LANGSMITH.md.
# To reactivate: add "langsmith" to OPENCLAW_OTEL_EXPORTERS, fill in
# the values below, and `make deploy`. Header format is exact:
# x-api-key=<key>,Langsmith-Project=<project> with no space after comma.
LANGSMITH_TRACING=false
LANGSMITH_ATTACH_AUDIO=false
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.smith.langchain.com/otel
# OTEL_EXPORTER_OTLP_HEADERS=x-api-key=your-langsmith-api-key,Langsmith-Project=openclaw-livekit
# LANGSMITH_PROJECT_NYLA=Nyla
# LANGSMITH_PROJECT_AOI=Aoi
# LANGSMITH_PROJECT_PARTY=Party
# Set to "true" only for low-level tracing investigations.
LANGSMITH_VERBOSE_TELEMETRY=false
# Legacy alias for OPENCLAW_OTEL_DEBUG.
LANGSMITH_PROCESSOR_DEBUG=false
