# LiveKit voice agent secrets — EXAMPLE / TEMPLATE.
#
# Copy to secrets/livekit-agents.env at the repo root (gitignored) and fill in
# real values. Docker Compose loads it via `env_file:` for every agent
# container (see docker-compose.agents.yaml); scripts/agent-entrypoint.sh then
# resolves the per-agent MUSUBI_V2_TOKEN_<AGENT> into the unsuffixed
# MUSUBI_V2_TOKEN the SDK reads.
#
# Rotation workflow:
#   1. Update value(s) in secrets/livekit-agents.env.
#   2. `make cycle` — recreates the agent containers so the new env takes
#      effect. (Infra containers: `make up`.)

# ---- LiveKit (shared by all agents) ----
# Must match livekit.yaml and livekit-sip.yaml.
LIVEKIT_URL=ws://livekit-server:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-change-me-before-real-use

# ---- External APIs ----
# Google Gemini API key — realtime voice agents (nyla, aoi, yua).
# NOTE: this single key is a household single-point-of-failure — one revoked or
# rate-limited key stops all three realtime agents at once. Per-agent keys
# (GOOGLE_API_KEY_<AGENT>) are the intended hardening; see ADR 0008.
# Sumi's line uses no cloud STT/LLM/TTS keys — her whole stack is local
# (Riva ASR + Mistral Nemo/llama.cpp + Orpheus on mizuki's Blackwell card).
GOOGLE_API_KEY=your-google-api-key-here

# ---- Musubi canonical API (agent-as-tenant per ADR 0030) ----
# Bearer JWTs minted from the Musubi core's JWT_SIGNING_KEY. Mint with:
#   python3 -c "import jwt,time; print(jwt.encode({'iss':'<oauth_authority>',
#     'aud':'musubi','sub':'livekit-<agent>',
#     'presence':'<agent>/voice','scope':'<agent>/*:rw <agent>/*/*:rw */*:r */*/*:r',
#     'iat':int(time.time()),'exp':int(time.time())+365*24*3600},
#     '<jwt_signing_key>', algorithm='HS256'))"
# One token per agent — each writes only to its own <agent>/voice namespace.
# Sumi's voice line has its own (sumi/voice), a distinct channel from her
# fleet presence (sumi/hermes).
MUSUBI_V2_BASE_URL=http://musubi.mey.house:8100/v1
MUSUBI_V2_TOKEN_NYLA=your-musubi-jwt-for-presence-nyla-voice
MUSUBI_V2_TOKEN_AOI=your-musubi-jwt-for-presence-aoi-voice
MUSUBI_V2_TOKEN_YUA=your-musubi-jwt-for-presence-yua-voice
MUSUBI_V2_TOKEN_SUMI=your-musubi-jwt-for-presence-sumi-voice

# ---- OpenTelemetry → OTLP backend ----
# Point this at your own OTLP/HTTP collector. A local Grafana LGTM stack,
# Grafana Cloud, Honeycomb, Datadog, or any other OTLP-compatible backend
# works without code changes. See docs/OBSERVABILITY.md.
VOICE_OTEL_ENABLED=true
# Resource identity stamped on every span and log.
VOICE_DEPLOYMENT_ENVIRONMENT=local
# Set to "true" for verbose stderr diagnostics + always-on console exporter.
VOICE_OTEL_DEBUG=false
# Set to "true" to keep LiveKit framework-noise spans (agent_speaking,
# on_enter, on_exit, drain_agent_activity, user_speaking) in the trace
# tree. Default = filter them so the trace view stays focused on
# conversation content.
VOICE_OTEL_VERBOSE=false
# Disable HTTP auto-instrumentation (httpx + aiohttp + requests) if it
# interferes with something. Our LiveKit Grafana dashboard's "HTTP
# Request Duration" panel reads `http.client.duration` from these.
VOICE_OTEL_HTTP_INSTRUMENTATION=true

# --- OTLP/HTTP exporter ---
# Local collector example. Replace for hosted backends.
VOICE_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Optional — only needed for backends that require an auth header.
# VOICE_OTLP_HEADERS=x-api-key=<key>

# --- OTel logs pipeline ---
# When enabled, Python `logging` records ship as OTLP log records to
# whatever the otlp exporter is pointed at. Trace correlation by trace_id
# is automatic. Auto-on alongside the OTLP traces exporter; set
# explicitly to "false" to disable.
VOICE_OTEL_LOGS_ENABLED=true
# Optional explicit logs endpoint (defaults to VOICE_OTLP_ENDPOINT
# with /v1/traces rewritten to /v1/logs).
# VOICE_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs

# --- OTel metrics pipeline ---
# Auto-on alongside the OTLP traces exporter; set explicitly to "false"
# to disable. Powers SystemMetricsInstrumentor + http.client.duration
# histograms feeding the Mimir-backed Grafana dashboards.
# VOICE_OTEL_METRICS_ENABLED=true
# VOICE_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
# VOICE_OTLP_METRICS_HEADERS=x-api-key=<key>

# --- Audio recording (opt-in) ---
# When ON, livekit-egress writes each call's audio to disk under the egress
# recordings mount. See docs/OBSERVABILITY.md "Audio recording".
VOICE_RECORD_AUDIO=false
# VOICE_AUDIO_PUBLIC_BASE_URL=https://media.example/recordings
# Host/container recording dirs — defaults align with the egress bind-mount
# in docker-compose.yaml (./logs/voice/recordings -> /recordings).
LIVEKIT_EGRESS_HOST_RECORDINGS_DIR=./logs/voice/recordings
LIVEKIT_EGRESS_CONTAINER_RECORDINGS_DIR=/recordings
