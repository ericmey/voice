# livekit-egress configuration.
#
# Copy to config/livekit-egress.yaml (gitignored) before starting the
# voice-livekit-egress container. Keys here must match livekit.yaml.
# The egress container writes local recordings to /recordings, which
# docker-compose bind-mounts to ./logs/voice/recordings on the host.

log_level: info

api_key: "devkey"
api_secret: "devsecret-change-me-before-real-use"

# livekit-egress is a bridge container on the compose network, so it reaches
# the server and redis by service name (both Linux and Mac). Keep ws_url
# aligned with LIVEKIT_URL in secrets.
ws_url: "ws://livekit-server:7880"

redis:
  address: "redis:6379"

# Chrome sandbox needs SYS_ADMIN in Docker; compose grants it on the
# egress service. Keeping the sandbox enabled matches LiveKit's default.
enable_chrome_sandbox: true
