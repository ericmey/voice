{
  "_comment": [
    "Dispatch rule for the phone-sumi agent (fully-local chained STT/LLM/TTS).",
    "See sip-dispatch-nyla.json.example for the full field explanation."
  ],

  "dispatch_rule": {
    "name": "twilio-to-phone-sumi",

    "numbers": [
      "+15550000003"
    ],

    "rule": {
      "dispatchRuleIndividual": {
        "roomPrefix": "phone"
      }
    },

    "room_config": {
      "agents": [
        {
          "agentName": "phone-sumi",
          "metadata": "{\"route\":\"sumi\",\"source\":\"sip\"}"
        }
      ]
    }
  }
}
