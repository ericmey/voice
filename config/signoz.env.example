# Template for secrets/signoz.env (gitignored — copy this file to that path
# and fill in real values).
#
# Used by:
#   - scripts/signoz-import-dashboards.sh (autoloaded by `make signoz-import-dashboards`)
#   - scripts/signoz-admin.sh             (raw curl wrapper for ad-hoc admin calls)
#
# Generate the API key in the SigNoz UI:
#   1. Open http://localhost:8080
#   2. Click the gear icon (Settings) → "API Keys" (or "Service Accounts" on
#      v0.130+; SigNoz is migrating to service accounts as of v0.151).
#   3. New key → role: SigNoz-Admin → optional expiration → Create.
#   4. Copy the key value once (SigNoz only displays it on creation).
#   5. Paste it as SIGNOZ_API_KEY below in secrets/signoz.env.

# Recommended: a SigNoz-Admin API key (full read+write on dashboards,
# alerts, services, settings).
SIGNOZ_API_KEY=

# Local URL of the SigNoz frontend. Override only if you proxy SigNoz.
SIGNOZ_URL=http://localhost:8080

# Fallback auth (used only when SIGNOZ_API_KEY is empty). The email +
# password from the SigNoz first-run UI signup.
SIGNOZ_USER=
SIGNOZ_PASS=
