# LiveKit voice agent — one image, agent selected at runtime.
FROM python:3.12-slim

# build deps for native wheels (livekit, grpc, audio libs)
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential curl ca-certificates libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# uv (pinned installer)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app
# workspace metadata first for layer caching
COPY pyproject.toml uv.lock ./
COPY sdk ./sdk
COPY tools ./tools
COPY agents ./agents
# build the workspace venv
RUN uv sync --frozen --no-dev

COPY scripts/agent-entrypoint.sh ./scripts/agent-entrypoint.sh
RUN chmod +x ./scripts/agent-entrypoint.sh

# service.version in every span/metric. Baked at build time so it describes the code
# in THIS image rather than whatever the deploy shell happened to have checked out.
# The retired launchd deploy derived it from `git rev-parse --short HEAD`.
ARG VOICE_SERVICE_VERSION=dev
ENV VOICE_SERVICE_VERSION=${VOICE_SERVICE_VERSION}

# AGENT selects which agent dir runs (aoi|nyla|yua|sumi). The entrypoint maps that to the
# per-agent Musubi bearer and sets LIVEKIT_VOICE_LOGS before exec.
#
# DELIBERATELY NOT SET HERE. This image must never answer the identity question.
#
# It used to read `ENV AGENT=aoi`, which disarmed both of the entrypoint's guards: the
# `${AGENT:?}` check can never fire when the image has already set AGENT, and the `*)`
# fallthrough can never be reached. A container started without an explicit AGENT did not
# fail — it silently BECAME AOI: registered as `phone-aoi`, read MUSUBI_V2_TOKEN_AOI, and
# wrote its memories into `aoi/voice`. `assert_agent_identity` could not catch it either,
# because VOICE_AGENT_NAME derives from the same $AGENT, so the cross-check compared the
# default against itself and passed.
#
# That is `NYLA_DEFAULT_CONFIG` reincarnated one layer down — the precise bug
# sdk/src/sdk/config.py exists to prevent. It was dormant only because all four compose
# services happen to pass AGENT. Dormant is not fixed.
#
# An identity default is never a convenience. It is a silent misattribution waiting for the
# first container someone starts by hand. AGENT is supplied by the caller (see
# docker-compose.agents.yaml), and its absence is a hard failure by design.
ENTRYPOINT ["/app/scripts/agent-entrypoint.sh"]
