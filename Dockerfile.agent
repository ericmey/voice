# LiveKit voice agent — one image, agent selected at runtime.
FROM python:3.12-slim

# build deps for native wheels (livekit, grpc, audio libs)
RUN apt-get update && apt-get install -y --no-install-recommends \
      build-essential curl ca-certificates libffi-dev \
    && rm -rf /var/lib/apt/lists/*

# uv (pinned installer)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

WORKDIR /app
# workspace metadata first for layer caching
COPY pyproject.toml uv.lock ./
COPY sdk ./sdk
COPY tools ./tools
COPY agents ./agents
# build the workspace venv
RUN uv sync --frozen --no-dev

COPY scripts/agent-entrypoint.sh ./scripts/agent-entrypoint.sh
RUN chmod +x ./scripts/agent-entrypoint.sh

# AGENT selects which agent dir runs (aoi|nyla|yua|party). The entrypoint maps
# that to the per-agent Musubi bearer and sets LIVEKIT_VOICE_LOGS before exec.
ENV AGENT=aoi
ENTRYPOINT ["/app/scripts/agent-entrypoint.sh"]
